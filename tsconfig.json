{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "stores": ["packages/core/src"],
      "@/env": ["packages/core/src/env.web.ts"],
      "@/store/batchStoreNotifications": ["packages/core/src/store/batchStoreNotifications.web.ts"],
      "@/store/attachStoreHook": ["packages/core/src/store/attachStoreHook.react.ts"],
      "@/storage": ["packages/core/src/storesStorage.web.ts"]
    }
  },
  "include": ["packages/*/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
