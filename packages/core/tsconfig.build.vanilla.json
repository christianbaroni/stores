{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "declarationMap": false,
    "declarationDir": "dist/vanilla",
    "moduleSuffixes": [".vanilla", ""],
    "paths": {
      "@/env": ["src/env.web.ts"],
      "@/store/batchStoreNotifications": ["src/store/batchStoreNotifications.web.ts"],
      "@/store/attachStoreHook": ["src/store/attachStoreHook"],
      "@/storage": ["src/storesStorage.web.ts"]
    },
    "tsBuildInfoFile": ".tsbuildinfo.vanilla"
  },
  "include": ["src/index.vanilla.ts"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "**/tests/**"]
}
