{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "types": ["node", "chrome"],
    "declaration": true,
    "emitDeclarationOnly": true,
    "composite": true,
    "declarationDir": "dist",
    "declarationMap": true,
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "stripInternal": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/env": ["src/env.web.ts"],
      "@/store/batchStoreNotifications": ["src/store/batchStoreNotifications.web.ts"],
      "@/store/attachStoreHook": ["src/store/attachStoreHook.react.ts"],
      "@/storage": ["src/storesStorage.web.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.test.ts", "**/*.testUtils.ts"]
}
