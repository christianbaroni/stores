{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "types": ["node", "vitest/globals"],
    "noEmit": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/env": ["src/env.web.ts"],
      "@/store/batchStoreNotifications": ["src/store/batchStoreNotifications.web.ts"],
      "@/store/attachStoreHook": ["src/store/attachStoreHook.react.ts"],
      "@/storage": ["src/storesStorage.web.ts"]
    }
  },
  "include": ["src/**/*", "build/**/*", "tsup.config.ts"]
}
